## Google OAuth 2.0
## Create credentials at https://console.cloud.google.com/apis/credentials
## Authorised redirect URI: http://YOUR_HOST:8080/auth/google/callback

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

## Callback URL (update to your public hostname/IP)
GOOGLE_CALLBACK_URL=http://31.171.250.25:8080/auth/google/callback

## Session secret (generate a random string)
SESSION_SECRET=change_me_to_a_random_secret_string

## JWT secret for API tokens
JWT_SECRET=change_me_to_another_random_secret

## Port
PORT=8080
